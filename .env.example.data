# UnfranchisedFC Data Architecture Configuration
# This file defines all API keys, endpoints, and data sources

# ===== LIVE MATCH DATA =====

# API-Football (RapidAPI)
# Sign up: https://rapidapi.com/api-sports/api/api-football
# Get key from RapidAPI dashboard
API_FOOTBALL_KEY=your_api_football_key_here
API_FOOTBALL_HOST=api-football-v1.p.rapidapi.com

# Alternative: Sportmonks
# Sign up: https://www.sportmonks.com/
SPORTMONKS_API_KEY=your_sportmonks_key_here

# ===== WIKIPEDIA API =====
# No authentication needed - free tier
WIKIPEDIA_API_URL=https://en.wikipedia.org/w/api.php

# ===== REDDIT SENTIMENT =====
# Set up OAuth at: https://www.reddit.com/prefs/apps
# Create a "script" type app
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=UnfranchisedFC/1.0 (by your_username)

# ===== TWITTER/X API =====
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
TWITTER_API_URL=https://api.twitter.com/2

# ===== LLM BACKEND =====
# OpenCode Zen (FREE - runs locally in VS Code)
LLM_BACKEND=opencode
OPENCODE_API_URL=http://localhost:8000

# Alternative: Together.ai (fallback - costs ~$0.0008 per 1K tokens)
TOGETHER_API_KEY=your_together_api_key_here

# ===== MEDIA GENERATION =====
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ===== INSTAGRAM POSTING =====
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# Meta Graph API (for business accounts)
META_ACCESS_TOKEN=your_meta_access_token_here
IG_BUSINESS_ACCOUNT_ID=your_ig_business_account_id_here

# ===== OUTPUT =====
OUTPUT_DIR=./output

# ===== DATA SOURCES CONFIGURATION =====
# World Cup 2026 base camps data location
BASE_CAMPS_JSON=./data/base_camps.json

# Reddit subreddits to monitor
REDDIT_SUBREDDITS=USLPRO,MLS

# RSS feeds to track
RSS_FEEDS_ENABLED=true
