# GitHub Actions Environment Variables
# Copy this to .env for local testing (DO NOT commit .env to repo)
# Add these as secrets in GitHub repo settings

# === LLM Backend (Choose One) ===

# OPTION 1: OpenCode Zen (RECOMMENDED - Free, no API key needed)
# The VS Code OpenCode extension handles auth automatically.
# Models: big-pickle, minimax-m2.5-free, mimo-v2-pro-free, nemotron-3-super-free
LLM_BACKEND=opencode  # or "together" or "auto" (tries opencode first)
OPENCODE_API_URL=http://localhost:8000  # Local OpenCode server (if running locally)
OPENCODE_TOKEN=  # Leave empty if using VS Code extension

# OPTION 2: Together.ai (Fallback - costs ~$0.0008 per 1K tokens)
# Get from: https://www.together.ai/
TOGETHER_API_KEY=your_together_api_key_here

# === Text-to-Speech API (ElevenLabs) ===
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Get from: https://elevenlabs.io/

# === Instagram Posting ===
# Option 1: Personal/Test Account (instagrapi)
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# Option 2: Business Account (Meta Graph API) - RECOMMENDED for production
META_ACCESS_TOKEN=your_meta_access_token
IG_BUSINESS_ACCOUNT_ID=your_ig_business_account_id

# === Data Sources ===
SPORTS_API_KEY=your_sports_api_key_optional
NEWS_API_KEY=your_news_api_key_optional
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_optional

# === Output Directory ===
OUTPUT_DIR=./output

# === Privacy & Security ===
# WARNING: OpenCode Zen (free tier) may use your data for model training.
# If working with sensitive/proprietary code:
#   1. Use Together.ai (paid) or local Ollama instead
#   2. Or upgrade to OpenCode Go ($10/month) for better privacy
# See README.md for details.
